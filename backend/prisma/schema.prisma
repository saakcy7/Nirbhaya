generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int              @id @default(autoincrement())
  name         String
  email        String           @unique
  phone        String           @unique
  passwordHash String
  createdAt    DateTime         @default(now())
  
  // Relations
  contacts     TrustedContact[]
  incidents    Incident[]       // Prisma tracks this collection...
  sosAlerts    SOSAlert[]
}


model TrustedContact {
  id             Int     @id @default(autoincrement())
  userId         Int
  name           String
  email          String
  phone          String?
  notifyViaSms   Boolean @default(true)
  notifyViaEmail Boolean @default(false)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Incident {
  id           Int      @id @default(autoincrement())
  reporterId   Int?     // This maps to the physical database column
  
  // 1. ADD THIS LINE: This defines the structural object relationship for Prisma
  reporter     User?    @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  latitude     Float
  longitude    Float
  incidentType String
  severity     Int      @default(1)
  description  String?
  areaName     String?
  timeOfDay    Int?
  reportedAt   DateTime @default(now())
  isVerified   Boolean  @default(false)
}


model SOSAlert {
  id          Int             @id @default(autoincrement())
  userId      Int?            // <--- Added "?" to make this column nullable
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull) // <--- Changed to User? and SetNull
  latitude    Float
  longitude   Float
  message     String          @default("I need help! Please check on me immediately.")
  status      String          @default("active")
  triggeredAt DateTime        @default(now())
  resolvedAt  DateTime?
}